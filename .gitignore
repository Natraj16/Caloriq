# ─────────────────────────────────────────────────────────
# Caloriq — Root .gitignore
# ─────────────────────────────────────────────────────────

# IDEs & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS-specific files
.DS_Store
Thumbs.db

# Backend local database & environment variables
backend/*.db
backend/*.db-journal
backend/.env

# Python compilation and virtual environments
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Frontend dependency trees & builds
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Prompt and planning files
caloriq_plan.md
caloriq_prompt.md
task.md
next-step.txt
walkthrough.md
implementation_plan.md
.gemini/
*.log
*.db
*.db-journal
