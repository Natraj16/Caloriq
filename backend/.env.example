# ─────────────────────────────────────────────────────────
# Caloriq — Backend Environment Variables Configuration Template
# Copy this file to '.env' and fill in your values.
# ─────────────────────────────────────────────────────────

# ── App configuration ────────────────────────────────────
DEBUG=true

# ── Database ─────────────────────────────────────────────
# Default is SQLite for local development.
# In production, swap to PostgreSQL by overriding this variable:
# DATABASE_URL=sqlite:///./caloriq.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/caloriq

# ── Redis (Optional Caching Layer) ───────────────────────
# Leave empty to automatically fall back to the in-memory cache provider.
# REDIS_URL=redis://localhost:6379/0

# ── Authentication ───────────────────────────────────────
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── External AI & Database Integrations ──────────────────

# Gemini AI API Key (Required for Text & Photo Analysers)
# Get a free API Key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# USDA FoodData Central Key (Optional Fallback Client)
# Get a free API Key at: https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=your_usda_api_key_here
